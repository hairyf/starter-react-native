{
  "name": "react-native",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start -c",
    "dev:android": "expo start -c --android",
    "dev:ios": "expo start -c --ios",
    "dev:web": "expo start -c --web",
    "reusables": "pnpm -C reusables reusables",
    "prebuild": "expo prebuild",
    "typecheck": "tsc --noEmit",
    "prepare": "simple-git-hooks",
    "postinstall": "pnpx skills experimental_install",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev && tsx scripts/migrations.ts",
    "lint": "eslint .",
    "clean": "rm -rf .expo node_modules",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@hairy/react-lib": "catalog:frontend",
    "@hairy/utils": "catalog:frontend",
    "@tanstack/react-query": "catalog:frontend",
    "expo": "catalog:expo",
    "expo-sqlite": "catalog:expo",
    "kysely": "catalog:sql",
    "kysely-dialect-expo": "catalog:sql",
    "kysely-migrate-sql": "catalog:sql",
    "kysely-model": "catalog:sql",
    "react": "catalog:frontend",
    "react-dom": "catalog:frontend",
    "react-native": "catalog:native",
    "react-native-mmkv": "catalog:native",
    "react-native-nitro-modules": "catalog:native",
    "react-use": "catalog:frontend",
    "reusables": "workspace:*",
    "unstorage": "catalog:frontend",
    "valtio": "catalog:frontend",
    "valtio-define": "catalog:frontend"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:cli",
    "@eslint-react/eslint-plugin": "catalog:cli",
    "@types/react": "catalog:types",
    "babel-plugin-inline-import": "catalog:build",
    "eslint": "catalog:cli",
    "eslint-plugin-format": "catalog:cli",
    "eslint-plugin-react-hooks": "catalog:cli",
    "eslint-plugin-react-refresh": "catalog:cli",
    "expo-constants": "catalog:expo",
    "expo-haptics": "catalog:expo",
    "expo-linking": "catalog:expo",
    "expo-router": "catalog:expo",
    "expo-splash-screen": "catalog:expo",
    "expo-status-bar": "catalog:expo",
    "expo-system-ui": "catalog:expo",
    "expo-updates": "catalog:expo",
    "lint-staged": "catalog:cli",
    "prisma": "catalog:sql",
    "prisma-kysely": "catalog:sql",
    "react-native-gesture-handler": "catalog:native",
    "react-native-keyboard-controller": "catalog:native",
    "react-native-reanimated": "catalog:native",
    "react-native-safe-area-context": "catalog:native",
    "react-native-screens": "catalog:native",
    "react-native-web": "catalog:native",
    "react-native-worklets": "catalog:native",
    "simple-git-hooks": "catalog:cli",
    "tailwindcss": "catalog:build",
    "tsx": "catalog:cli",
    "typescript": "catalog:dev",
    "uniwind": "catalog:build"
  },
  "pnpm": {
    "patchedDependencies": {
      "valtio@2.3.0": "patches/valtio@2.3.0.patch"
    }
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
