{
  "name": "react-native",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start -c",
    "dev:android": "expo start -c --android",
    "dev:ios": "expo start -c --ios",
    "dev:web": "expo start -c --web",
    "reusables": "pnpm -C reusables reusables",
    "prebuild": "expo prebuild",
    "typecheck": "tsc --noEmit",
    "prepare": "simple-git-hooks",
    "postinstall": "pnpx skills experimental_install",
    "lint": "eslint .",
    "clean": "rm -rf .expo node_modules",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@hairy/react-lib": "^1.47.0",
    "@hairy/utils": "^1.47.0",
    "@tanstack/react-query": "^5.90.21",
    "expo": "~54.0.33",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-mmkv": "^4.2.0",
    "react-native-nitro-modules": "^0.35.0",
    "react-use": "^17.6.0",
    "reusables": "workspace:*",
    "unstorage": "^1.17.4",
    "valtio": "^2.3.0",
    "valtio-define": "^1.1.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.6.1",
    "@eslint-react/eslint-plugin": "^2.13.0",
    "@types/react": "~19.1.10",
    "eslint": "^10.0.2",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "expo": "~54.0.29",
    "expo-constants": "~18.0.12",
    "expo-haptics": "~15.0.8",
    "expo-linking": "~8.0.10",
    "expo-router": "~6.0.19",
    "expo-splash-screen": "~31.0.12",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.15",
    "lint-staged": "16.3.2",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.1.17",
    "typescript": "~5.9.2",
    "uniwind": "^1.2.2"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
